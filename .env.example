# --- Trendyol ---
# Satıcı Paneli > Hesap Bilgilerim > Entegrasyon Bilgileri
TRENDYOL_SELLER_ID=
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=

# --- Shopify ---
# Mağazanın KALICI .myshopify.com adı (custom domain DEĞİL). Örn: xst1gd-b8.myshopify.com
SHOPIFY_SHOP=
# İki auth yolundan BİRİNİ doldur:
#  (A) Klasik custom app (admin > Develop apps): tek statik token
SHOPIFY_ACCESS_TOKEN=
#  (B) Dev dashboard uygulaması: client credentials (24 saatlik token otomatik alınır)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Gerekli scope'lar: read_orders, read_fulfillments (read_orders korumalı — merchant onayı ister)
# İsteğe bağlı: acil sayılacak etiket (varsayılan: acil)
SHOPIFY_URGENT_TAG=acil

# --- Ayarlar ---
# Açılışta sorulan basit giriş şifresi (boş bırakılırsa: lufie)
SITE_PASSWORD=lufie
# Termini kaç gün içinde dolacaklar da "gecikecek" sayılsın (0 = bugün ve geçmiş)
DELAY_OFFSET_DAYS=0
# Pano kaç saniyede bir yenilensin
REFRESH_SECONDS=60
# Alt grafikler için günlük geçmiş dosyası. Yerelde boş bırakılabilir (proje klasörüne yazar).
# Railway'de KALICI Volume mount edip buraya /data/history.json verin (yoksa redeploy'da grafik geçmişi silinir).
# HISTORY_FILE=/data/history.json
